# ─── Supabase Postgres (Prisma) ──────────────────────────────────────────────
# Supabase → Connect → ORMs → Prisma
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[POOLER-HOST]:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[POOLER-HOST]:5432/postgres"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="[LONG-RANDOM-STRING]"
NEXTAUTH_URL="http://localhost:3000"   # in production, set to your deployed URL

# ─── Supabase Storage (photo uploads) ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
# Supabase → Settings → API → "service_role" secret key. Server-only, keep secret.
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SERVICE-ROLE-KEY]"

# ─── Seeding (optional) ──────────────────────────────────────────────────────
# Used only by prisma/seed.ts to create the admin user:
# ADMIN_EMAIL="you@example.com"
# ADMIN_PASSWORD="a-strong-password"
